{
  "name": "camera-ai-assistant",
  "version": "0.1.0",
  "type": "module",
  "description": "摇光 - 摄像头AI对话助手",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "dev:bun": "bun run --bun src/main/electrobun.ts",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "camera",
    "ai",
    "vision",
    "dialog"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/three": "^0.184.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.0.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "electrobun": "^1.16.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
