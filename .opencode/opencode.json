{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "./AGENTS.md"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "./.opencode/hooks/pre-bash-guard.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "./.opencode/hooks/resource-guard.sh",
            "timeout": 2
          }
        ]
      },
      {
        "matcher": "Write|Edit|Delete",
        "hooks": [
          {
            "type": "command",
            "command": "./.opencode/hooks/decision-gate.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "./.opencode/hooks/coordinator-guard.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "./.opencode/hooks/pre-tool-validate.sh",
            "timeout": 2
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "./.opencode/hooks/post-edit-verify.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "./.opencode/hooks/dual-check-hook.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "./.opencode/hooks/post-tool-verify.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "PreModeling": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./.opencode/hooks/pre-model-check.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "PostVerification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./.opencode/hooks/self-improvement-trigger.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .opencode/scripts/auto-verify.sh",
            "timeout": 60
          }
        ]
      }
    ]
  },
  "permission": {
    "edit": "ask",
    "bash": "ask",
    "delete": "ask"
  },
  "resourceLimits": {
    "maxTokensPerTask": 180000,
    "maxToolCalls": 500,
    "maxLoopIterations": 200,
    "maxTaskDurationMinutes": 30,
    "maxMemoryMB": 2048
  },
  "harness": {
    "version": "2.0.0",
    "mode": "strict",
    "selfImprovement": {
      "autoTrigger": true,
      "maxIterations": 3
    },
    "dangerousCommands": {
      "mode": "prompt",
      "patterns": {
        "block": ["rm -rf /", "mkfs", "shutdown", "reboot"],
        "prompt": ["rm ", "curl.*|", "chmod ", "dd", ">:", "| sh"]
      }
    }
  }
}
